# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hcs_cms_db

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200

# External SSO / Resource Server
SSO_INTROSPECTION_URL=http://localhost:9000/o/introspect/
SSO_CLIENT_ID=resource-server-client
SSO_CLIENT_SECRET=resource-server-secret
SSO_VERIFY_SSL=False

# CIS 1.0 Legacy Database (for introspection only)
CIS_LEGACY_DB_NAME=cis_legacy
CIS_LEGACY_DB_USER=cis_user
CIS_LEGACY_DB_PASSWORD=cis_password
